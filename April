-- 辅助函数：更新移速显示和滑块位置（基于对数映射）
local function getLogT(value)
    -- value 范围 1 ~ 1e9，映射到 0~1 对数
    local minV = 1
    local maxV = 1e9
    local logMin = math.log(minV)
    local logMax = math.log(maxV)
    local logVal = math.log(value)
    return (logVal - logMin) / (logMax - logMin)
end

local function getValueFromLogT(t)
    local minV = 1
    local maxV = 1e9
    local logMin = math.log(minV)
    local logMax = math.log(maxV)
    local logVal = logMin + t * (logMax - logMin)
    return math.exp(logVal)
end

local function updateWalkSpeedUI()
    local current = humanoid.WalkSpeed
    speedInput.Text = tostring(math.floor(current + 0.5))
    local t = getLogT(current)
    t = math.clamp(t, 0, 1)
