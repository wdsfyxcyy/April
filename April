local function loadLibrary(url)
    local success, lib = pcall(game.HttpGet, game, url)
    if success then
        return loadstring(lib)()
    end
    return nil
end

local Library = loadLibrary(repo .. 'Library.lua')
if not Library then
    Library = loadLibrary(backupRepo .. 'Library.lua')
end

