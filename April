-- 飞行功能实现
local function startFly()
    if flyEnabled then return end
    flyEnabled = true
    flyButton.Text = "飞行 [开启]"
    -- 保存原重力
    local originalGravity = workspace.Gravity
    workspace.Gravity = 0
    humanoid.PlatformStand = true
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
    
    -- 飞行更新循环
    flyConnection = runService.RenderStepped:Connect(function()
        if not flyEnabled or not rootPart.Parent then return end
        local move = Vector3.new(0, 0, 0)
        -- 获取键盘输入（WASD + 空格/Ctrl 上下）
        if userInputService:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0, 0, -1) end
        if userInputService:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0, 0, 1) end
        if userInputService:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1, 0, 0) end
        if userInputService:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1, 0, 0) end
        if userInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
        if userInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move = move + Vector3.new(0, -1, 0) end
        
        if move.Magnitude > 0 then
            move = move.Unit
        end
        -- 基于相机方向计算速度向量
        local cameraCF = camera.CFrame
        local forward = cameraCF.LookVector
        local right = cameraCF.RightVector
        local up = cameraCF.UpVector
        local velocityDirection = (right * move.X + up * move.Y + forward * -move.Z).Unit
        local targetVelocity = velocityDirection * flySpeed
        bodyVelocity.Velocity = targetVelocity
        -- 保持角色朝向
        if targetVelocity.Magnitude > 0.1 then
            bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + targetVelocity)
        end
    end)
end

local function stopFly()
    if not flyEnabled then return end
    flyEnabled = false
    flyButton.Text = "飞行 [关闭]"
    workspace.Gravity = 196.2  -- 恢复默认重力
    humanoid.PlatformStand = false
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    if flyConnection then flyConnection:Disconnect() end
    bodyVelocity = nil
    bodyGyro = nil
    flyConnection = nil
end

local function toggleFly()
    if flyEnabled then
        stopFly()
    else
        startFly()
    end
end

