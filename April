-- 穿墙核心逻辑
local function onNoclip()
    if not noclipEnabled then return end
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide then
            part.CanCollide = false
        end
    end
end

local noclipConnection
local function toggleNoclip()
    noclipEnabled = not noclipEnabled
    noclipButton.Text = noclipEnabled and "穿墙 [开启]" or "穿墙 [关闭]"
    if noclipEnabled then
        onNoclip()
        noclipConnection = runService.Heartbeat:Connect(onNoclip)
    else
        if noclipConnection then noclipConnection:Disconnect() end
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

-- 透视玩家 (Highlight 方式，边缘颜色可调)
local espObjects = {}
local function updateESP()
    if not espEnabled then
        for _, obj in pairs(espObjects) do
            if obj and obj.Parent then obj:Destroy() end
        end
        espObjects = {}
        return
    end
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character then
            if not espObjects[plr] then
                local highlight = Instance.new("Highlight")
                highlight.FillColor = espFillColor
                highlight.OutlineColor = espOutlineColor
                highlight.FillTransparency = 0.6
                highlight.Parent = plr.Character
                espObjects[plr] = highlight
            else
                -- 更新颜色
                espObjects[plr].OutlineColor = espOutlineColor
                espObjects[plr].FillColor = espFillColor
            end
        end
    end
    for plr, highlight in pairs(espObjects) do
        if not plr.Parent or not plr.Character or plr.Character.Parent == nil then
            highlight:Destroy()
            espObjects[plr] = nil
        end
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    espButton.Text = espEnabled and "透视玩家 [开启]" or "透视玩家 [关闭]"
    updateESP()
    if espEnabled then
        players.PlayerAdded:Connect(function(newPlr)
            task.wait(1)
            updateESP()
        end)
        players.PlayerRemoving:Connect(function(plr)
            if espObjects[plr] then
                espObjects[plr]:Destroy()
                espObjects[plr] = nil
            end
        end)
    end
end

